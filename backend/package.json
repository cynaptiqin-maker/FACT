{
  "name": "fact-finos-backend",
  "version": "1.0.0",
  "description": "FACT FinOS - Hospital Financial Operating System Backend",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "db:sync": "node -e \"require('./src/config/database').sync()\"",
    "db:seed": "node src/database/seed.js",
    "db:migrate": "sequelize-cli db:migrate",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "test:integration": "jest --runInBand --testPathPattern='__tests__/(integration|unit)' --forceExit",
    "queues:ui": "bull-board"
  },
  "dependencies": {
    "express": "^4.19.2",
    "sequelize": "^6.37.3",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "ioredis": "^5.3.2",
    "bullmq": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "joi": "^17.13.1",
    "winston": "^3.13.0",
    "morgan": "^1.10.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "express-slow-down": "^2.0.1",
    "openai": "^4.52.7",
    "langchain": "^0.2.11",
    "@langchain/openai": "^0.2.5",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.15.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.14",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.4",
    "axios": "^1.7.2",
    "decimal.js": "^10.4.3",
    "dayjs": "^1.11.11",
    "lodash": "^4.17.21",
    "compression": "^1.7.4",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg-connection-string": "^2.6.4",
    "cls-hooked": "^4.2.2",
    "events": "^3.3.0",
    "cron": "^3.1.7",
    "handlebars": "^4.7.8",
    "archiver": "^7.0.1",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.6.0",
    "eslint-plugin-import": "^2.29.1",
    "@types/jest": "^29.5.12"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.js", "**/?(*.)+(spec|test).js"],
    "setupFilesAfterEnv": ["./src/__tests__/setup.js"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"],
    "coveragePathIgnorePatterns": ["/node_modules/", "/src/__tests__/"],
    "testPathIgnorePatterns": ["/node_modules/", "src/__tests__/setup\\.js"],
    "collectCoverageFrom": [
      "src/shared/**/*.js",
      "src/middleware/**/*.js",
      "src/modules/**/services/*.js",
      "src/modules/**/controllers/*.js"
    ]
  }
}
